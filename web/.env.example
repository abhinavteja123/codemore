# =============================================================================
# CodeMore Web App - Environment Configuration
# =============================================================================

# Authentication (NextAuth.js)
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_secret_here

# GitHub OAuth - Create at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# Optional: use "repo" only if you need private repository access
GITHUB_OAUTH_SCOPE=read:user user:email public_repo

# Google OAuth - Create at https://console.cloud.google.com/apis/credentials (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Supabase (free tier) - Create at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key  # WARNING: never expose client-side

# Encryption for scan job artifacts (generate: openssl rand -base64 32)
CODEMORE_JOB_ENCRYPTION_KEY=

# Upstash Redis for rate limiting (upstash.com) - Optional
# Falls back to in-memory rate limiting if not configured
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Error tracking (sentry.io) - Optional but recommended for production
SENTRY_DSN=

# AI Provider Keys - Optional, for AI-powered fixes
# Configure based on your preferred provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

